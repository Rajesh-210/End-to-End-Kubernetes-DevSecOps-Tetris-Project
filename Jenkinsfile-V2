pipeline {
    agent any

    tools {
        nodejs 'nodejs'
    }

    environment {
        SCANNER_HOME = tool 'sonar-scanner'
        DOCKER_REGISTRY = 'https://index.docker.io/v1/'
        IMAGE_NAME = 'chilukurir/tetrisv2'
        GIT_REPO = 'Rajesh-210/End-to-End-Kubernetes-DevSecOps-Tetris-Project'
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout Source Code') {
            steps {
                git branch: 'master',
                    url: 'https://github.com/Rajesh-210/End-to-End-Kubernetes-DevSecOps-Tetris-Project.git'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('Tetris-V2') {
                    withSonarQubeEnv('sonar-scanner') {
                        sh """
                        ${SCANNER_HOME}/bin/sonar-scanner \
                        -Dsonar.projectName=Tetris-V2 \
                        -Dsonar.projectKey=Tetris-V2
                        """
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                waitForQualityGate abortPipeline: false
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('Tetris-V2') {
                    sh 'npm install'
                }
            }
        }

        stage('OWASP Dependency Check') {
            steps {
                dir('Tetris-V2') {
                    withCredentials([string(credentialsId: 'nvd-api-key', variable: 'NVD_API_KEY')]) {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            dependencyCheck(
                                odcInstallation: 'DP-Check',
                                additionalArguments: "--scan ./ --nvdApiKey ${NVD_API_KEY} --disableAssembly --disableYarnAudit --disableNodeAudit"
                            )
                        }
                    }
                    dependencyCheckPublisher pattern: '**/dependency-check-report.xml'
                }
            }
        }

        stage('Trivy File Scan') {
            steps {
                dir('Tetris-V2') {
                    sh 'trivy fs --scanners vuln . > trivyfs.txt'
                }
            }
        }

        stage('Docker Build Image') {
            steps {
                dir('Tetris-V2') {
                    sh "docker build -t tetrisv2:${BUILD_NUMBER} ."
                }
            }
        }

        stage('Docker Push Image') {
            steps {
                withDockerRegistry(credentialsId: 'docker', url: "${DOCKER_REGISTRY}") {
                    sh """
                        docker tag tetrisv2:${BUILD_NUMBER} ${IMAGE_NAME}:${BUILD_NUMBER}
                        docker push ${IMAGE_NAME}:${BUILD_NUMBER}

                        docker tag tetrisv2:${BUILD_NUMBER} ${IMAGE_NAME}:latest
                        docker push ${IMAGE_NAME}:latest
                    """
                }
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh "trivy image --scanners vuln ${IMAGE_NAME}:${BUILD_NUMBER} > trivyimage.txt"
            }
        }

        stage('Update Kubernetes Manifest') {
            steps {
                dir('Manifest-file') {
                    withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
                        sh """
                            git config user.email "rajeshchilukuri522@gmail.com"
                            git config user.name "Rajesh-210"

                            CURRENT_TAG=\$(grep -oP '(?<=tetrisv2:)[^ ]+' deployment-service.yml)

                            sed -i "s/tetrisv2:\${CURRENT_TAG}/tetrisv2:${BUILD_NUMBER}/" deployment-service.yml

                            git add deployment-service.yml
                            git commit -m "Update tetrisv2 image to version ${BUILD_NUMBER}" || echo "No changes"

                            git push https://${GITHUB_TOKEN}@github.com/${GIT_REPO} HEAD:master
                        """
                    }
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'Tetris-V2/trivyfs.txt, trivyimage.txt', allowEmptyArchive: true
        }

        success {
            echo "Tetris V2 deployed successfully 🚀"
        }

        failure {
            echo "Pipeline failed ❌ Check logs"
        }
    }
}
